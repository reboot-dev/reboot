#!/usr/bin/env sh
#
# Reboot Claude Code plugin: `node` bootstrap shim.
#
# Claude Code prepends this script's directory to the agent's `PATH`, so
# the agent's `node ...` invocations land here. Sibling of
# `bin/npm`; both delegate to `lib/install_node.sh` and exec
# binaries from the same cached Node install.

set -eu

PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "$(dirname -- "$0")/.." && pwd)}"

NODE_DIR="$("$PLUGIN_ROOT/lib/install_node.sh")"

exec "$NODE_DIR/bin/node" "$@"
