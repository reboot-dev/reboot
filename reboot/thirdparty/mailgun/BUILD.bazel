load("@rbt_pypi//:requirements.bzl", "requirement")
load("@rules_python//python:defs.bzl", "py_library")

py_library(
    name = "__init___py",
    srcs = ["__init__.py"],
    srcs_version = "PY3",
    visibility = ["//visibility:public"],
    deps = [
        ":settings_py",
    ],
)

py_library(
    name = "settings_py",
    srcs = ["settings.py"],
    srcs_version = "PY3",
    visibility = ["//visibility:public"],
)

py_library(
    name = "servicers_py",
    srcs = [
        "servicers.py",
    ],
    visibility = ["//visibility:public"],
    deps = [
        requirement("aiohttp"),
        ":__init___py",
        ":settings_py",
        "//reboot/aio:call_py",
        "//reboot/aio:contexts_py",
        "//reboot/aio:secrets_py",
        "//reboot/aio/auth:authorizers_py",
        "@com_github_reboot_dev_reboot//rbt/thirdparty/mailgun/v1:mailgun_py_reboot",
        "@com_github_reboot_dev_reboot//reboot:run_environments_py",
        "@com_github_reboot_dev_reboot//reboot/aio/auth:token_verifiers_py",
    ],
)
