<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Who do you want to be?</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link
  href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400..700&display=swap"
  rel="stylesheet">
<style>
  :root {
    --cream: #F7F5ED;
    --navy: #103761;
    --blue: #266AB2;
    --light-blue: #A4D1FF;
    --tan: #A39382;
  }
  body {
    font-family: "DM Sans", "Helvetica Neue", Arial, sans-serif;
    background: var(--cream);
    margin: 0;
    display: flex;
    min-height: 100vh;
    align-items: center;
    justify-content: center;
    color: var(--navy);
  }
  .card {
    background: #fff;
    border: 1px solid rgba(16, 55, 97, 0.12);
    border-radius: 16px;
    width: 380px;
    padding: 36px 0 12px;
    box-shadow: 0 10px 30px rgba(16, 55, 97, 0.12);
  }
  .logo {
    display: block;
    height: 30px;
    width: auto;
    margin: 0 auto 20px;
  }
  h1 {
    font-size: 24px;
    font-weight: 600;
    text-align: center;
    margin: 0 0 4px;
    color: var(--navy);
  }
  .subtitle {
    text-align: center;
    color: var(--tan);
    font-size: 14px;
    margin: 0 0 20px;
  }
  .account {
    display: flex;
    align-items: center;
    padding: 12px 28px;
    text-decoration: none;
    color: inherit;
    transition: background 0.15s ease;
  }
  .account:hover {
    background: rgba(164, 209, 255, 0.22);
  }
  .avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    font-weight: 600;
    margin-right: 16px;
    flex: 0 0 auto;
  }
  .identity {
    display: flex;
    flex-direction: column;
  }
  .name {
    font-size: 15px;
    font-weight: 500;
    color: var(--navy);
  }
  .email {
    font-size: 13px;
    color: var(--tan);
  }
  .footer {
    text-align: center;
    color: var(--tan);
    font-size: 12px;
    padding: 20px 28px 8px;
  }
</style>
</head>
<body>
  <div class="card">
    <svg class="logo" viewBox="0 0 924 247" fill="none"
         xmlns="http://www.w3.org/2000/svg" aria-label="Reboot">
      <path fill="#103761" d="M81.8761 82.8232C98.9505 82.8232 114.795 88.1208 127.876 97.1714L107.285 132.836C100.312 127.123 91.4465 123.722 81.8761 123.722C59.8126 123.722 41.4889 141.791 41.4884 164.62H41.4931V246.417H0.589844V164.62C0.590406 119.445 36.9833 82.8237 81.8761 82.8232Z"/>
      <path fill="#103761" d="M128.679 164.998C128.679 209.964 165.132 246.417 210.098 246.417V206.506C187.174 206.506 168.59 187.922 168.59 164.998C168.59 142.074 187.174 123.491 210.098 123.491C225.461 123.491 238.875 131.838 246.052 144.244H210.098V184.954H289.053C290.662 178.568 291.516 171.883 291.516 164.998C291.516 120.032 255.064 83.5796 210.098 83.5796C165.132 83.5796 128.679 120.032 128.679 164.998Z"/>
      <path fill="#103761" fill-rule="evenodd" clip-rule="evenodd" d="M349.603 0V164.108C349.603 186.978 368.143 205.518 391.013 205.518C413.883 205.518 432.423 186.978 432.423 164.108C432.423 141.237 413.883 122.697 391.013 122.697H380.788V81.7981H391.013C436.471 81.7981 473.322 118.649 473.322 164.108C473.322 209.566 436.471 246.417 391.013 246.417C345.555 246.417 308.704 209.566 308.704 164.108V0H349.603Z"/>
      <path fill="#266AB2" d="M502.609 207.794C506.061 213.358 510.239 218.591 515.153 223.345L543.481 193.702C542.494 192.734 541.569 191.725 540.702 190.681L502.609 207.794Z"/>
      <path fill="#A4D1FF" d="M552.342 243.963C558.534 245.521 565.006 246.375 571.668 246.417V205.414C570.372 205.397 569.088 205.314 567.822 205.176L552.342 243.963Z"/>
      <path fill="#3285DE" d="M524.048 230.785C529.281 234.598 535.051 237.843 541.312 240.386L556.509 202.303C555.266 201.789 554.063 201.216 552.898 200.592L524.048 230.785Z"/>
      <path fill="#103761" d="M572.308 82.8203C617.484 82.8208 654.106 119.444 654.106 164.619C654.106 176.319 651.648 187.444 647.223 197.508L609.917 180.705C612.032 175.767 613.206 170.331 613.206 164.619C613.206 142.032 594.895 123.721 572.308 123.721C549.721 123.721 531.41 142.032 531.41 164.619C531.41 170.331 532.582 175.769 534.697 180.707L497.404 197.537C492.971 187.465 490.509 176.33 490.509 164.619C490.509 119.443 527.132 82.8203 572.308 82.8203Z"/>
      <path fill="#103761" d="M833.861 163.596C833.865 163.937 833.867 164.278 833.867 164.619C833.867 209.795 797.474 246.417 752.58 246.417C707.687 246.417 671.293 209.795 671.293 164.619C671.293 119.615 707.411 83.099 752.069 82.8223V123.723C730.234 124 712.192 141.965 712.192 164.619C712.192 187.449 730.516 205.518 752.58 205.518C774.644 205.518 792.968 187.449 792.968 164.619C792.968 164.277 792.964 163.936 792.956 163.596H833.861Z"/>
      <path fill="#103761" d="M891.953 160.68C891.953 181.093 905.247 198.402 923.65 204.421V246.417C882.462 239.591 851.054 203.803 851.054 160.68V43.9712L891.953 43.9712V82.4759H923.65V123.375H891.953V160.68Z"/>
    </svg>
    <h1>Who do you want to be?</h1>
    <p class="subtitle">pick an identity to log in as</p>
    {% for account in accounts %}
    <a class="account" href="{{ account.href }}">
      <span class="avatar" style="background: {{ account.color }};">{{ account.initial }}</span>
      <span class="identity">
        <span class="name">{{ account.name }}</span>
        <span class="email">{{ account.email }}</span>
      </span>
    </a>
    {% endfor %}
    <p class="footer">
      Reboot development sign-in<br />
      fake identities for local development
    </p>
  </div>
</body>
</html>
