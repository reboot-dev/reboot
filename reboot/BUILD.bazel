py_library(
    # This library represents the full Reboot Python library as distributed
    # to PyPI. If a dependency is (transitively) listed here, it will be in the
    # distributed library. If it's not, then it won't be.
    name = "python",
    data = [
        ":py_typed",
        "@com_github_reboot_dev_reboot//rbt:py_typed",
        "@com_github_reboot_dev_reboot//rebootdev:py_typed",
    ],
    deps = [
        ":api_py",
        ":python_std",
        ":python_thirdparty",
        ":protobuf_py",
        ":protoc_gen_reboot_nodejs_py",
        ":protoc_gen_reboot_react_py",
        ":protoc_gen_reboot_nodejs_boilerplate_py",
        ":protoc_gen_reboot_web_py",
        "@com_github_reboot_dev_reboot//protoc_gen_mypy_plugin:protoc-gen-mypy",
        "@com_github_reboot_dev_reboot//rebootdev:protoc_gen_es_with_deps_py",
        "@com_github_reboot_dev_reboot//rebootdev:protoc_gen_reboot_python_boilerplate_py",
        "@com_github_reboot_dev_reboot//rebootdev:protoc_gen_reboot_python_py",
        "//reboot/aio:python",
        "//reboot/cli:rbt_main_py",
        "//reboot/experimental:python",
        "//reboot/nodejs:python",
        # TODO: This dependency is excluded from the `//reboot/aio:python` target, in order
        # to avoid creating a cycle with the code generated by:
        #   `//rbt/cloud/v1alpha1/secrets:secrets_py_reboot`
        # ... we should likely split out the portion of `//reboot/aio:python` that is actually
        # required by the stub code.
        "//reboot/aio:secrets_py",
    ],
)

