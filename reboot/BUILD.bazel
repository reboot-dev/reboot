    visibility = ["//visibility:public"],
    deps = [
        "@com_github_reboot_dev_reboot//rebootdev:api_py",
    ],
)

pip_package(
    # Packages published to PyPI ideally have a normalized name:
    #   https://packaging.python.org/en/latest/specifications/name-normalization/#normalization
    # To avoid confusion, our target names use the same normalized form.
    #
    # NOTE: this definition also exposes a `reboot.dev` target that can be used
    #       to build a quicker-to-build-but-not-publishable version of the pip
    #       package for use during development; the naming `reboot.dev` is a
    #       coincidence and does not refer to the company name.
    name = "reboot",
    description = "The Reboot library",
    license = "Apache-2.0",
    license_txt = ":LICENSE.txt",
    readme_md = ":README.public.md",
    requirements_txt = "@com_github_reboot_dev_reboot//rebootdev:requirements.in",
    scripts = {
        # NOTE: the protoc compiler insists that the name of a plugin must(!!!!) start with
        # `protoc-gen-`.
        # TODO(rjh): distribute separate protoc plugins for the different languages;
        #            currently the plugin builds all supported languages.
        "protoc-gen-es_with_deps": "rebootdev.protoc_gen_es_with_deps:main",
        "protoc-gen-mypy": "protoc_gen_mypy_plugin.protoc_gen_mypy_wrapper:main",
        "protoc-gen-reboot_nodejs": "reboot.protoc_gen_reboot_nodejs:main",
        "protoc-gen-reboot_nodejs_boilerplate": "reboot.protoc_gen_reboot_nodejs_boilerplate:main",
        "protoc-gen-reboot_python": "rebootdev.protoc_gen_reboot_python:main",
        "protoc-gen-reboot_python_boilerplate": "rebootdev.protoc_gen_reboot_python_boilerplate:main",
        "protoc-gen-reboot_react": "reboot.protoc_gen_reboot_react:main",
        "protoc-gen-reboot_web": "reboot.protoc_gen_reboot_web:main",
        "rbt": "reboot.cli.rbt_main:main",
    },
    version = REBOOT_VERSION,
    visibility = ["//visibility:public"],
    deps = [
        ":python",
    ],
)

# TODO: This `sh_library` is a necessary indirection until Bazel 6, because a `sh_binary`
# does not actually force a `data` attribute to build, but a `sh_library` does. We can
# remove the indirection once we upgrade. See https://github.com/bazelbuild/bazel/issues/12348
sh_library(
    name = "force_reinstall_dev_reboot_lib",
    srcs = [
        "force_reinstall.sh",
    ],
    data = [
        ":reboot.dev",
    ],
)

sh_binary(
    name = "force_reinstall_dev_reboot",
    srcs = [
        "force_reinstall.sh",
    ],
    args = [
        "$(location :reboot.dev)",
    ],
    data = [
        ":reboot.dev",
    ],
    deps = [":force_reinstall_dev_reboot_lib"],
)

