# Find '.proto' files in 'api/'.
generate api/

# Tell `rbt generate` where to put generated files.
generate --python=backend/api

generate --react=web/api

# The mobile (React Native) client. Metro (React Native's bundler)
# resolves imports without file extensions, so we do not enable
# `--react-extensions`; the generated client's relative imports stay
# extensionless and resolve under both Vite (web) and Metro (mobile).
generate --mobile=mobile/src/api

# Watch if any generated or source files are modified.
dev run --watch=backend/**/*.py

# Tell `rbt` that this is a Python application.
dev run --python

# Save state between chaos restarts.
dev run --application-name=bank

# Run the application!
dev run --application=backend/src/main.py

# When expunging, expunge that state we've saved.
dev expunge --application-name=bank
