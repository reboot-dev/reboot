{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "//comment1": "Run the generate-code-snippets command in bash rather than sh to get access to globstar functionality",
    "generate-code-snippets": "bash -c \"shopt -s globstar && npx -y markdown-autodocs -c code-block -o './docs/**/*.md*' && python unindent_auto_doc.py './docs/**/*.md*'\"",
    "build": "docusaurus build && printf '\n \n NOTE!: disregard warnings for remarkAdmonitions and broken anchor on /library_services/**/*\n \n'",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@docusaurus/core": "3.8.0",
    "@docusaurus/plugin-google-gtag": "^3.8.0",
    "@docusaurus/preset-classic": "3.8.0",
    "@mdx-js/react": "^3.1.0",
    "clsx": "^2.0.0",
    "npm-run-all": "^4.1.5",
    "prism-react-renderer": "^2.4.1",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "rehype-react": "^8.0.0",
    "remark-directive": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "watch": "^0.13.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.8.0",
    "@docusaurus/tsconfig": "3.8.0",
    "@docusaurus/types": "3.8.0",
    "@tsconfig/docusaurus": "^2.0.3",
    "autoprefixer": "^10.4.20",
    "param-case": "4.0.0",
    "postcss": "^8.5.4",
    "tailwindcss": "^3.4.9",
    "typescript": "~5.5.2"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=16.14"
  }
}
