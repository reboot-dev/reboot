# Find 'zod' schema files in 'api/'.
generate ../api/

# Generate code for a TypeScript/nodejs backend and React frontend.
generate --nodejs=../api

# Add extensions so that we can run the application with `node` in tests.
generate --nodejs-extensions

dev run --watch=src/**/*.ts

dev run --name=bank-zod-yarn

dev run --nodejs

dev run --application=src/main.ts

dev expunge --name=bank-zod-yarn
