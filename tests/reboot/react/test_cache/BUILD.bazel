vitest_test(
    name = "test_local_storage",
    timeout = "long",
    config = "vitest-local_storage.config.mjs",
    data = [
        ":storage_type_local_storage_test_ts",
        "//reboot:reboot.dev",
    ],
    # To use a "dev" version of Reboot instead of a publicly released
    # version of Reboot in the test, we set the 'REBOOT_WHL_FILE'
    # environment variable to point to the Reboot wheel file to install
    # from.
    env = {"REBOOT_WHL_FILE": "$(rootpath //reboot:reboot.dev)"},
    node_modules = "//:node_modules",
    visibility = ["//visibility:public"],
)

vitest_test(
    name = "test_in_memory",
    timeout = "long",
    config = "vitest-in_memory.config.mjs",
    data = [
        "disableLocalStorage.mjs",
        ":storage_type_in_memory_test_ts",
        "//reboot:reboot.dev",
    ],
    # To use a "dev" version of Reboot instead of a publicly released
    # version of Reboot in the test, we set the 'REBOOT_WHL_FILE'
    # environment variable to point to the Reboot wheel file to install
    # from.
    env = {"REBOOT_WHL_FILE": "$(rootpath //reboot:reboot.dev)"},
