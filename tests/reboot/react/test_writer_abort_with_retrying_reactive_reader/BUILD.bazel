load("@aspect_rules_esbuild//esbuild:defs.bzl", "esbuild")
load("@aspect_rules_ts//ts:defs.bzl", "ts_project")
load("@com_google_protobuf//bazel:proto_library.bzl", "proto_library")
load("@rules_python//python:defs.bzl", "py_library")
load(
    "//reboot:rules.bzl",
    "js_proto_library",
    "js_reboot_library",
    "js_reboot_react_library",
    "py_reboot_library",
)
load("//tests/reboot/react:py_web_test_suite_env.bzl", "py_web_test_suite_env")

proto_library(
    name = "test_proto",
    srcs = [
        ":test.proto",
    ],
    visibility = ["//visibility:public"],
    deps = [
        "//rbt/v1alpha1:options_proto",
        "@com_google_protobuf//:empty_proto",
    ],
)

py_reboot_library(
    name = "test_py_reboot",
    proto = "test.proto",
    proto_library = ":test_proto",
    visibility = ["//visibility:public"],
)

js_proto_library(
    name = "test_js_proto",
    package_json = ":package.json",
    proto = "test.proto",
    proto_deps = [
        ":test_proto",
        "@com_google_protobuf//:empty_proto",
        # ISSUE(https://github.com/reboot-dev/mono/issues/3218): Until
        # we can use `create_protoc_plugin_rule` we need to repeat the
        # dependencies of the `proto_libraries` here.
        "//rbt/v1alpha1:options_proto",
        "@com_google_protobuf//:descriptor_proto",
    ],
    visibility = ["//visibility:public"],
)

js_reboot_library(
    name = "test_js_reboot",
    srcs = [
        ":test_proto",
    ],
    proto = "test.proto",
    visibility = ["//visibility:public"],
    deps = [
        ":test_js_proto",
    ],
)

js_reboot_react_library(
    name = "test_js_reboot_react",
    srcs = [
        ":test_js_proto",
    ],
    proto = "test.proto",
    proto_deps = [
        ":test_proto",
    ],
    visibility = ["//visibility:public"],
)

py_library(
    name = "test_servicers_py",
    srcs = [
        "test_servicers.py",
    ],
    visibility = ["//tests:__subpackages__"],
    deps = [
        ":test_py_reboot",
    ],
)

ts_project(
    name = "index_ts",
    srcs = [
        "index.tsx",
    ],
    tsconfig = "//tests/reboot/react:tsconfig",
    deps = [
        ":test_js_reboot_react",
        "//:node_modules/@reboot-dev/reboot-react",
        "//:node_modules/react",
        "//:node_modules/react-dom",
        "//rbt/v1alpha1:tasks_js_proto",
    ],
)

esbuild(
    name = "bundle",
    srcs = [
        ":index_ts",
    ],
    entry_point = "index.js",
    format = "esm",
    platform = "browser",
)

py_library(
    name = "test_py",
    testonly = True,
    srcs = ["test.py"],
    data = [
        ":bundle",
    ],
    deps = [
        ":test_servicers_py",
        "//tests/reboot/react:web_driver_runner",
    ],
)

py_web_test_suite_env(
    name = "test_against_local_envoy_py",
    srcs = ["test_against_local_envoy.py"],
    browsers = [
        "@io_bazel_rules_webtesting//browsers:chromium-local",
    ],
    main = "test_against_local_envoy.py",
    # This test is not supported on macOS; see:
    #   https://github.com/reboot-dev/mono/issues/4067.
    py_test_tags = [
        "macos_not_supported",
        "requires-linux-x86",
        "flaky",
    ],
    tags = [
        "flaky",
        "macos_not_supported",
        "requires-linux-x86",
    ],
    deps = [
        ":test_py",
        "//tests/reboot/react:test_against_local_envoy_py",
    ],
)
