        "@com_google_protobuf//:descriptor_proto",
        "@com_google_protobuf//:timestamp_proto",
    ],
)

py_reboot_library(
    name = "task_py_reboot",
    proto = "task.proto",
    proto_library = ":task_proto",
    visibility = ["//tests/reboot:__subpackages__"],
)

# This `py_library` is needed to trigger the build and `mypy` checks of
# code which we use in the docs.
