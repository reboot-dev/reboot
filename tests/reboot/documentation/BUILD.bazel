# The `get_started` tutorial's Pydantic API definition, pulled as
# the tested `main.py` entrypoint snippet in
# `documentation/docs/ai_chat_apps/get_started.mdx`.
py_library(
    name = "ai_chat_counter_py",
    srcs = ["ai_chat_counter.py"],
    deps = ["//reboot:api_py"],
)

# Generates the `_rbt` code from the API definition at build time, so
# the servicer is checked against real generated code.
py_reboot_library_from_pydantic(
    name = "ai_chat_counter_py_reboot",
    py_deps = [":ai_chat_counter_py"],
    pydantic = ":ai_chat_counter.py",
)

# The tutorial's servicer, importable as `servicers.counter` so the
# `main.py` snippet's `from servicers.counter import ...` resolves the
# way a real app's does. The `backend/src` import root mirrors the
# real app's layout and keeps the API definition (which the generated
# `_rbt` code imports by its full path) out of the root, so `mypy`
# names each source consistently.
py_library(
    name = "ai_chat_counter_servicer_py",
    srcs = [
        "backend/src/servicers/__init__.py",
        "backend/src/servicers/counter.py",
    ],
    imports = ["backend/src"],
    deps = [
        ":ai_chat_counter_py",
        ":ai_chat_counter_py_reboot",
    ],
)

# The `get_started` entrypoint, pulled as the `main.py` snippet in
# `documentation/docs/ai_chat_apps/get_started.mdx`.
py_library(
    name = "get_started_main_py",
    srcs = ["backend/src/main.py"],
    imports = ["backend/src"],
    deps = [":ai_chat_counter_servicer_py"],
)

# Exercises the tutorial's `User` and `Counter` servicers, and checks
# the `main.py` snippet is real, importable code.
py_test(
    name = "test_ai_chat_counter_py",
    srcs = ["test_ai_chat_counter.py"],
    imports = ["backend/src"],
    main = "test_ai_chat_counter.py",
    deps = [
        ":ai_chat_counter_servicer_py",
        ":get_started_main_py",
        "//reboot/aio:applications_py",
        "//reboot/aio:tests_py",
    ],
)

js_reboot_react_library_from_pydantic(
    name = "ai_chat_counter_js_reboot_react",
    package_json = ":package.json",
    pydantic = ":ai_chat_counter.py",
)

# Type-checks the `get_started` React entrypoint (`main.tsx`) and the
# `App` it renders against the generated hooks, so the `main.tsx`
# snippet the docs pull stays real. The `@api/...` alias maps the
# tutorial's import path onto the Bazel-generated hooks module.
ts_project(
    name = "get_started_main_ts",
    srcs = [
        "App.tsx",
        "get_started_env.d.ts",
        "get_started_main.tsx",
        ":package.json",
    ],
    declaration = True,
    tsconfig = {
        "compilerOptions": {
            "baseUrl": ".",
            "jsx": "react-jsx",
            "lib": [
                "ES2022",
                "DOM",
                "DOM.Iterable",
            ],
            "module": "esnext",
            "moduleResolution": "bundler",
            "paths": {
                "@api/ai_chat_counter/v1/counter_rbt_react": [
                    "./ai_chat_counter_zod_rbt_react",
                ],
            },
            "skipLibCheck": True,
            "strict": True,
            "target": "es2022",
        },
    },
    deps = [
        ":ai_chat_counter_js_reboot_react",
        "//:node_modules/@reboot-dev/reboot-react",
        "//:node_modules/@reboot-dev/reboot-web",
        "//:node_modules/@types/react",
        "//:node_modules/react",
        "//:node_modules/react-dom",
        "//:node_modules/zod",
    ],
)
