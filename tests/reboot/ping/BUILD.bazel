load("@rbt_pypi//:requirements.bzl", "requirement")
load("@rules_python//python:defs.bzl", "py_test")

py_test(
    name = "ping_test",
    size = "small",
    timeout = "short",
    srcs = ["ping_test.py"],
    deps = [
        # The `ping` application is originally defined in
        # `public/reboot/ping` and is symlinked in the `mono`.
        # We use the "local" Bazel targets to refer here to avoid
        # dealing with cross-repository paths in Bazel during
        # `Pydantic-to-proto` generation.
        "//reboot:api_py",
        "//reboot/aio:applications_py",
        "//reboot/ping:ping_py",
        "//reboot/aio:tests_py",
        requirement("httpx"),
    ],
)
