load("@rules_python//python:defs.bzl", "py_library")
load("//tests/reboot/react:py_web_test_suite_env.bzl", "py_web_test_suite_env")

# End-to-end browser test for the standalone Ping SPA. Rather than
# bundling a bespoke test SPA, it drives the *real* SPA the backend
# serves at `/__/frontend/web/` (built by `//reboot/ping:web_dist`,
# carried in `ping_py`'s runfiles). It exercises sign-in (cross-host
# OAuth + cookie + `/whoami`-derived bearer JWT), `User.create_counter`
# (writer over the WebSocket multiplex), and `Counter.increment`
# (writer over the same multiplex), then asserts the reactive read of
# `Counter.value` observes the new value. The SPA is driven on the
# `localhost` host with a `?rebootUrl=http://127.0.0.1:...` param, so
# its credentialed traffic is genuinely cross-origin; Envoy CORS
# trusts those loopback origins under `RBT_DEV`.

py_library(
    name = "test_py",
    testonly = True,
    srcs = ["test.py"],
    deps = [
        "//log:log_py",
        "@io_bazel_rules_webtesting//testing/web",
    ],
)

py_web_test_suite_env(
    name = "test_against_local_envoy_py",
    srcs = ["test_against_local_envoy.py"],
    browsers = [
        "@io_bazel_rules_webtesting//browsers:chromium-local",
    ],
    main = "test_against_local_envoy.py",
    # Mirrors `test_auth/`: Selenium-driven WebDriver tests are
    # macOS-unsupported by `io_bazel_rules_webtesting` today.
    py_test_tags = [
        "macos_not_supported",
        "requires-linux-x86",
    ],
    tags = [
        "macos_not_supported",
        "requires-linux-x86",
    ],
    deps = [
        ":test_py",
        "//reboot:settings_py",
        "//reboot/aio:applications_py",
        "//reboot/aio:health_check_py",
        "//reboot/aio:tests_py",
        "//reboot/aio/auth:oauth_providers_py",
        "//reboot/ping:ping_py",
    ],
)
