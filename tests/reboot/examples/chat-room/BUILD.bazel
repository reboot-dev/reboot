load("//reboot:versions.bzl", "REBOOT_VERSION")
load("//tests:sh_test_in_working_directory.bzl", "sh_test_in_working_directory")

# The following package paths are relative to the working directory of
# the test script.
shared_env = {
    "EXPECTED_RBT_DEV_OUTPUT_FILE": "tests/reboot/examples/chat-room/expected_output.txt",
}

devcontainer_env = dict(shared_env)

devcontainer_env.update({
    # Our workstations must use the "development" version of the wheel,
    # since they cannot build the release version.
    "REBOOT_WHL_FILE": "$(location //reboot:reboot.dev)",
})

osx_env = dict(devcontainer_env)

osx_env.update({
    # Our OSX CI machines don't have Docker.
    "REBOOT_LOCAL_ENVOY_MODE": "executable",
})

manylinux_env = dict(shared_env)

manylinux_env.update({
    # Our `manylinux-runner` containers don't have Docker.
    "REBOOT_LOCAL_ENVOY_MODE": "executable",
    # Our `manylinux-runner` containers can build the release target of
    # the wheel file.
    "REBOOT_WHL_FILE": "$(location //reboot:reboot)",
})

sh_test_in_working_directory(
    name = "test",
    data = [
        "//reboot:reboot.dev",
        # The actual test script will be given access to all of the files in
        # the example.
        "//reboot/examples/chat-room:everything",
        "expected_output.txt",
    ],
    env = select({
        "@platforms//os:linux": devcontainer_env,
        "@platforms//os:osx": osx_env,
    }),
    # The following path is relative to the working directory.
    script = ".tests/test.sh",
    # In all our example tests, we initiate LocalEnvoy on the default
    # secure port 9991. We require 'exclusive' to not run multiple
    # tests, that use the same port, concurrently.
    tags = ["exclusive"],
    working_directory = "reboot/examples/chat-room/",
)

sh_test_in_working_directory(
    # Identical to `test` above, except it uses a wheel built exactly as
    # it will be released. That means this test can only run on
    # `manylinux` containers.
    name = "release_test",
    data = [
        # The release test is run against the to-be-released wheel package.
        "//reboot",
        # The actual test script will be given access to all of the files in
        # the example.
        "//reboot/examples/chat-room:everything",
        "expected_output.txt",
    ],
    env = manylinux_env,
    # The following path is relative to the working directory.
    script = ".tests/test.sh",
    # In all our example tests, we initiate LocalEnvoy on the default
    # secure port 9991. We require 'exclusive' to not run multiple
    # tests, that use the same port, concurrently.
    #
    # We need to set "manual", because the `//reboot:reboot` target
    # cannot be built on normal workstations - this test should only be
    # run in "manylinux" containers.
    tags = [
        "exclusive",
        "manual",
    ],
    working_directory = "reboot/examples/chat-room/",
)

sh_test_in_working_directory(
    name = "serve_test",
    size = "large",
    data = [
        "//rbt/v1alpha1:reboot-dev-reboot-api",
        "//reboot:reboot.dev",
        "//reboot/nodejs:reboot-dev-reboot-" + REBOOT_VERSION + ".tgz",
        "//reboot/containers/reboot-base:dev",
        # The actual test script will be given access to all of the files in
        # the example.
        "//reboot/examples/chat-room:everything",
        "//tests/reboot/examples/chat-room:serve_expected_output.txt",
    ],
    env = {
        "EXPECTED_CURL_OUTPUT_FILE": "tests/reboot/examples/chat-room/serve_expected_output.txt",
        "PUSH_REBOOT_BASE": "false",
        # We have to repeat the same ENV variables as in the `reboot-base:dev`
        # script.
        "REBOOT_API_NPM_PACKAGE": "$(location //rbt/v1alpha1:reboot-dev-reboot-api)",
        "REBOOT_NPM_PACKAGE": "$(location //reboot/nodejs:reboot-dev-reboot-" + REBOOT_VERSION + ".tgz)",
        "REBOOT_VERSION": REBOOT_VERSION,
        "REBOOT_WHL_FILE": "$(location //reboot:reboot.dev)",
    },
    # The following path is relative to the working directory.
    script = ".tests/serve_test.sh",
    # The following path is relative to the bazel sandbox directory.
    setup_script = "reboot/containers/reboot-base/dev",
    # In all our example tests, we initiate LocalEnvoy on the default
    # secure port 9991. We require 'exclusive' to not run multiple
    # tests, that use the same port, concurrently.
    tags = [
        "exclusive",
        "requires-docker",
    ],
    working_directory = "reboot/examples/chat-room/",
)

# The locally built Reboot npm packages that the frontends are
# type-checked against, instead of the published releases.
frontend_packages = [
    "//rbt/std:reboot-dev-reboot-std-api",
    "//rbt/v1alpha1:reboot-dev-reboot-api",
    "//reboot:reboot.dev",
    "//reboot/nodejs:reboot-dev-reboot-" + REBOOT_VERSION + ".tgz",
    "//reboot/std/react:reboot-dev-reboot-std-react",
    "//reboot/web:reboot-dev-reboot-web",
    "//reboot/react:reboot-dev-reboot-react",
]

frontend_env = {
    "REBOOT_API_NPM_PACKAGE": "$(location //rbt/v1alpha1:reboot-dev-reboot-api)",
    "REBOOT_NPM_PACKAGE": "$(location //reboot/nodejs:reboot-dev-reboot-" + REBOOT_VERSION + ".tgz)",
    "REBOOT_REACT_NPM_PACKAGE": "$(location //reboot/react:reboot-dev-reboot-react)",
    "REBOOT_STD_API_PACKAGE": "$(location //rbt/std:reboot-dev-reboot-std-api)",
    "REBOOT_STD_REACT_PACKAGE": "$(location //reboot/std/react:reboot-dev-reboot-std-react)",
    "REBOOT_WEB_NPM_PACKAGE": "$(location //reboot/web:reboot-dev-reboot-web)",
    "REBOOT_WHL_FILE": "$(location //reboot:reboot.dev)",
}

osx_frontend_env = dict(frontend_env)

osx_frontend_env.update({
    # Our OSX CI machines don't have Docker.
    "REBOOT_LOCAL_ENVOY_MODE": "executable",
})

# Builds and type-checks the React Native (Expo) front end against the
# locally built Reboot client. See `frontend/mobile/.tests/react_native_test.sh`.
sh_test_in_working_directory(
    name = "mobile_test",
    size = "large",
    data = frontend_packages + [
        # The actual test script will be given access to all of the
        # files in the example.
        "//reboot/examples/chat-room:everything",
    ],
    env = select({
        "@platforms//os:linux": frontend_env,
        "@platforms//os:osx": osx_frontend_env,
    }),
    # The following path is relative to the working directory. We use
    # the whole example as the working directory (not just `frontend/mobile/`)
    # so the sibling `api/` protos that the mobile client is generated
    # from are copied into the test sandbox; the script `cd`s into
    # `frontend/mobile/` itself.
    script = "frontend/mobile/.tests/react_native_test.sh",
    tags = ["exclusive"],
    working_directory = "reboot/examples/chat-room/",
)

# Native end-to-end test: runs the real app on a headless Android
# emulator (KVM-accelerated) and drives it with Maestro against a real
# Reboot backend. See `frontend/mobile/.tests/maestro_test.sh`. This is NOT
# hermetic: it needs the host's `/dev/kvm`, a single emulator, and a
# long-running Metro/Expo + backend. Hence `manual`, `local`/`no-sandbox`/`no-remote` (needs the device + KVM,
# can't run on remote executors), and `exclusive` (single emulator +
# port 9991). It only runs on x86_64 Linux with `/dev/kvm`, so
# `macos_not_supported` excludes the macOS jobs and `requires-linux-x86`
# excludes the arm64 jobs. The Android SDK + emulator + Maestro come
# from the devcontainer image.
sh_test_in_working_directory(
    name = "maestro_test",
    size = "large",
    data = frontend_packages + [
        "//reboot/examples/chat-room:everything",
    ],
    env = frontend_env,
    script = "frontend/mobile/.tests/maestro_test.sh",
    tags = [
        "exclusive",
        "local",
        "manual",
        "requires-linux-x86",
    ],
    working_directory = "reboot/examples/chat-room/",
)

sh_test_in_working_directory(
    name = "frontend_type_check_test",
    size = "large",
    data = frontend_packages + [
        "//reboot/examples/chat-room:everything",
    ],
    env = frontend_env,
    script = "frontend/.tests/type_check.sh",
    working_directory = "reboot/examples/chat-room/",
)
