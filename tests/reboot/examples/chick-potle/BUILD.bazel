load("//reboot:versions.bzl", "REBOOT_VERSION")
load("//tests:sh_test_in_working_directory.bzl", "sh_test_in_working_directory")

test_packages = [
    "//reboot:reboot.dev",
]

# TODO: This `sh_library` is a necessary indirection until Bazel
# 6, because a `sh_binary` does not actually force a `data`
# attribute to build, but a `sh_library` does. We can remove the
# indirection once we upgrade. See
# https://github.com/bazelbuild/bazel/issues/12348
sh_library(
    name = "test_packages",
    data = test_packages,
)

# The following package paths are relative to the working
# directory of the test script.
general_env = {
    "EXPECTED_RBT_DEV_OUTPUT_FILE": "tests/reboot/examples/chick-potle/expected_output.txt",
    "REBOOT_WHL_FILE": "$(location //reboot:reboot.dev)",
}

osx_env = dict(general_env)

osx_env.update({
    "REBOOT_LOCAL_ENVOY_MODE": "executable",
})

sh_test_in_working_directory(
    name = "test",
    data = test_packages + [
        ":test_packages",
        # The actual test script will be given access to all of
        # the files in the example.
        "//reboot/examples/chick-potle:everything",
        "expected_output.txt",
    ],
    env = select({
        "@platforms//os:linux": general_env,
        "@platforms//os:osx": osx_env,
    }),
    # The following path is relative to the working directory.
    script = ".tests/test.sh",
    # In all our example tests, we initiate LocalEnvoy on the
    # default secure port 9991. We require 'exclusive' to not run
    # multiple tests, that use the same port, concurrently.
    tags = ["exclusive"],
    working_directory = "reboot/examples/chick-potle/",
)

frontend_packages = [
    "//rbt/v1alpha1:reboot-dev-reboot-api",
    "//reboot:reboot.dev",
    "//reboot/nodejs:reboot-dev-reboot-" + REBOOT_VERSION + ".tgz",
    "//reboot/web:reboot-dev-reboot-web",
    "//reboot/react:reboot-dev-reboot-react",
]

frontend_env = {
    "REBOOT_API_NPM_PACKAGE": "$(location //rbt/v1alpha1:reboot-dev-reboot-api)",
    "REBOOT_NPM_PACKAGE": "$(location //reboot/nodejs:reboot-dev-reboot-" + REBOOT_VERSION + ".tgz)",
    "REBOOT_REACT_NPM_PACKAGE": "$(location //reboot/react:reboot-dev-reboot-react)",
    "REBOOT_WEB_NPM_PACKAGE": "$(location //reboot/web:reboot-dev-reboot-web)",
    "REBOOT_WHL_FILE": "$(location //reboot:reboot.dev)",
}

sh_test_in_working_directory(
    name = "frontend_type_check_test",
    size = "large",
    data = frontend_packages + [
        "//reboot/examples/chick-potle:everything",
    ],
    env = frontend_env,
    script = "frontend/.tests/type_check.sh",
    working_directory = "reboot/examples/chick-potle/",
)
