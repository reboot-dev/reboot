load("//reboot:versions.bzl", "REBOOT_VERSION")
load("//tests:sh_test_in_working_directory.bzl", "sh_test_in_working_directory")

test_packages = [
    "//reboot:reboot.dev",
]

# TODO: This `sh_library` is a necessary indirection until Bazel 6, because a `sh_binary`
# does not actually force a `data` attribute to build, but a `sh_library` does. We can
# remove the indirection once we upgrade. See https://github.com/bazelbuild/bazel/issues/12348
sh_library(
    name = "test_packages",
    data = test_packages,
)

# The following package paths are relative to the working directory of
# the test script.
general_env = {
    "EXPECTED_RBT_DEV_OUTPUT_FILE": "tests/reboot/examples/bank-pydantic/expected_output.txt",
    "REBOOT_WHL_FILE": "$(location //reboot:reboot.dev)",
}

osx_env = dict(general_env)

osx_env.update({
    "REBOOT_LOCAL_ENVOY_MODE": "executable",
})

sh_test_in_working_directory(
    name = "test",
    data = test_packages + [
        ":test_packages",
        # The actual test script will be given access to all of the files in
        # the example.
        "//reboot/examples/bank-pydantic:everything",
        "expected_output.txt",
    ],
    env = select({
        "@platforms//os:linux": general_env,
        "@platforms//os:osx": osx_env,
    }),
    # The following path is relative to the working directory.
    script = ".tests/test.sh",
    # In all our example tests, we initiate LocalEnvoy on the default
    # secure port 9991. We require 'exclusive' to not run multiple
    # tests, that use the same port, concurrently.
    tags = ["exclusive"],
    working_directory = "reboot/examples/bank-pydantic/",
)

# The locally built Reboot npm packages that the React Native front
# end is type-checked against, instead of the published releases.
mobile_test_packages = [
    "//rbt/v1alpha1:reboot-dev-reboot-api",
    "//reboot:reboot.dev",
    "//reboot/nodejs:reboot-dev-reboot-" + REBOOT_VERSION + ".tgz",
    "//reboot/web:reboot-dev-reboot-web",
    "//reboot/react:reboot-dev-reboot-react",
]

mobile_env = {
    "REBOOT_API_NPM_PACKAGE": "$(location //rbt/v1alpha1:reboot-dev-reboot-api)",
    "REBOOT_NPM_PACKAGE": "$(location //reboot/nodejs:reboot-dev-reboot-" + REBOOT_VERSION + ".tgz)",
    "REBOOT_REACT_NPM_PACKAGE": "$(location //reboot/react:reboot-dev-reboot-react)",
    "REBOOT_WEB_NPM_PACKAGE": "$(location //reboot/web:reboot-dev-reboot-web)",
    "REBOOT_WHL_FILE": "$(location //reboot:reboot.dev)",
}

osx_mobile_env = dict(mobile_env)

osx_mobile_env.update({
    # Our OSX CI machines don't have Docker.
    "REBOOT_LOCAL_ENVOY_MODE": "executable",
})

# Builds and type-checks the React Native (Expo) front end against the
# locally built Reboot client. See `mobile/.tests/react_native_test.sh`.
sh_test_in_working_directory(
    name = "mobile_test",
    size = "large",
    data = mobile_test_packages + [
        # The actual test script will be given access to all of the
        # files in the example.
        "//reboot/examples/bank-pydantic:everything",
    ],
    env = select({
        "@platforms//os:linux": mobile_env,
        "@platforms//os:osx": osx_mobile_env,
    }),
    # The following path is relative to the working directory. We use
    # the whole example as the working directory (not just `mobile/`)
    # so the sibling `api/` protos that the mobile client is generated
    # from are copied into the test sandbox; the script `cd`s into
    # `mobile/` itself.
    script = "mobile/.tests/react_native_test.sh",
    tags = ["exclusive"],
    working_directory = "reboot/examples/bank-pydantic/",
)

# Native end-to-end test: runs the real app on a headless Android
# emulator (KVM-accelerated) and drives it with Maestro against a real
# Reboot backend. See `mobile/.tests/maestro_test.sh`. This is NOT
# hermetic: it needs the host's `/dev/kvm`, a single emulator, and a
# long-running Metro/Expo + backend. Hence `manual` (opt-in, not every
# PR), `local` (needs the host device + KVM, so neither sandboxed nor
# run on a remote executor), `exclusive` (single emulator + port 9991),
# and `requires-linux-x86` (the emulator/system image are x86_64-only).
# The Android SDK + emulator + Maestro come from the devcontainer image.
sh_test_in_working_directory(
    name = "maestro_test",
    size = "large",
    data = mobile_test_packages + [
        "//reboot/examples/bank-pydantic:everything",
    ],
    env = mobile_env,
    script = "mobile/.tests/maestro_test.sh",
    tags = [
        "exclusive",
        "local",
        "manual",
        "requires-linux-x86",
    ],
    working_directory = "reboot/examples/bank-pydantic/",
)
