load("@aspect_rules_ts//ts:defs.bzl", "ts_project")
load("@fremtind_rules_vitest//vitest:defs.bzl", "vitest_test")

ts_project(
    name = "react_native_test_ts",
    srcs = [
        "react_native.test.ts",
        ":package.json",
    ],
    tsconfig = {
        "compilerOptions": {
            "declaration": True,
            "module": "nodenext",
            "moduleResolution": "nodenext",
            "skipLibCheck": True,
            "target": "es2020",
        },
    },
    deps = [
        "//:node_modules/@bufbuild/protobuf",
        "//:node_modules/@reboot-dev/reboot-api",
        "//:node_modules/@reboot-dev/reboot-web",
        "//rbt/v1alpha1:tasks_js_proto",
        "//reboot/std/vitest:vitest_ts",
        "//tests/reboot:greeter_js_proto",
    ],
)

# A fast, hermetic regression suite for the React Native compatibility
# of the `@reboot-dev/reboot-web` client. It does not spin up a Reboot
# server (no `reboot.dev` data or `REBOOT_WHL_FILE` env); it mocks the
# web globals and exercises the client's plumbing directly.
vitest_test(
    name = "test",
    config = "vitest.config.mjs",
    data = [
        ":react_native_test_ts",
    ],
    node_modules = "//:node_modules",
    visibility = ["//visibility:public"],
)
