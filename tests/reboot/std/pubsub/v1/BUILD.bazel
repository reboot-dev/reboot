load("@aspect_rules_ts//ts:defs.bzl", "ts_project")
load("@rules_python//python:defs.bzl", "py_test")
load("//reboot/nodejs:rules.bzl", "js_reboot_test")

py_test(
    name = "pubsub_tests_py",
    srcs = [":pubsub_tests.py"],
    main = "pubsub_tests.py",
    deps = [
        "//reboot/aio:tests_py",
        "//reboot/std/collections/queue/v1:queue_py",
        "//reboot/std/pubsub/v1:pubsub_py",
    ],
)

ts_project(
    name = "pubsub_tests_ts",
    srcs = [
        "pubsub_tests.ts",
        ":package.json",
    ],
    declaration = True,
    tsconfig = {
        "compilerOptions": {
            "declaration": True,
            "module": "nodenext",
            "moduleResolution": "nodenext",
            "target": "es2020",
        },
    },
    visibility = ["//visibility:public"],
    deps = [
        "//:node_modules/@bufbuild/protobuf",
        "//:node_modules/@reboot-dev/reboot",
        "//:node_modules/@reboot-dev/reboot-std",
        "//:node_modules/@types/node",
    ],
)

js_reboot_test(
    name = "test_pubsub_tests_ts",
    data = [
        ":pubsub_tests_ts",
    ],
    entry_point = "pubsub_tests.js",
    visibility = ["//visibility:public"],
)
