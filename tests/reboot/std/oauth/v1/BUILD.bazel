load("@aspect_rules_ts//ts:defs.bzl", "ts_project")
load("@rules_python//python:defs.bzl", "py_test")
load("//reboot/nodejs:rules.bzl", "js_reboot_test")

py_test(
    name = "oauth_tests_py",
    size = "medium",
    srcs = [":oauth_tests.py"],
    main = "oauth_tests.py",
    deps = [
        "//reboot/aio:tests_py",
        "//reboot/std/ciphertext/v1:ciphertext_py",
        "//reboot/std/collections/ordered_map/v1:ordered_map_py",
        "//reboot/std/oauth/v1:oauth_py",
        "@com_github_reboot_dev_reboot//rbt/std/ciphertext/v1:ciphertext_py_reboot",
        "@com_github_reboot_dev_reboot//rbt/std/oauth/v1:oauth_py_reboot",
    ],
)

ts_project(
    name = "oauth_tests_ts",
    srcs = [
        "oauth_tests.ts",
        ":package.json",
    ],
    declaration = True,
    tsconfig = {
        "compilerOptions": {
            "declaration": True,
            "module": "nodenext",
            "moduleResolution": "nodenext",
            "target": "es2020",
        },
    },
    visibility = ["//visibility:public"],
    deps = [
        "//:node_modules/@reboot-dev/reboot",
        "//:node_modules/@reboot-dev/reboot-std",
        "//:node_modules/@types/node",
    ],
)

js_reboot_test(
    name = "test_oauth_tests_ts",
    data = [
        ":oauth_tests_ts",
    ],
    entry_point = "oauth_tests.js",
    visibility = ["//visibility:public"],
)
